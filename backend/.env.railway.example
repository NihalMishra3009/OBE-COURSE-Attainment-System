# Railway Backend Environment Variables
# Copy these into Railway > Variables for the backend service.
# Get DATABASE_URL from Railway PostgreSQL plugin dashboard.

# PostgreSQL connection string from Railway (Railway auto-injects this if you link the Postgres plugin)
DATABASE_URL="postgres://user:password@host:5432/nba_obe"

# Strong random secret used to sign JWT login tokens (at least 32 characters recommended)
JWT_SECRET="replace_with_a_long_random_secret_minimum_32_characters"

# Railway injects PORT automatically, but this is a safe default
PORT="3000"

# Allow your Vercel frontend to make API calls (comma-separated if multiple frontends)
# Example: "https://obe-course-attainment-system.vercel.app,https://other-app.vercel.app"
CORS_ORIGIN="https://obe-course-attainment-system.vercel.app"

# Optional: Enable all origins for development (NOT recommended for production)
# CORS_ORIGIN="*"

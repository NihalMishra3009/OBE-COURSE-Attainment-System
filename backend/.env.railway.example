# Railway backend environment variables
# Copy these into Railway > Variables for the backend service.

# Your PostgreSQL connection string for Railway or an external provider like Supabase.
DATABASE_URL=postgres://user:password@host:5432/nba_obe

# Strong random secret used to sign login tokens.
JWT_SECRET=replace_with_a_long_random_secret

# Railway will usually inject PORT automatically, but keep this as a safe local default.
PORT=3000

# Allow your Cloudflare Pages frontend to call the API.
CORS_ORIGIN=https://obe-course-attainment-system.pages.dev
